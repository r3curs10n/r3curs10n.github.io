---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import Prose from "../components/Prose.astro";
---

<Layout title="About — Beyond Algorithms" description="About Beyond Algorithms.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Beyond Algorithms",
    "description": "About Beyond Algorithms.",
    "url": new URL("/about", Astro.site).href,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Beyond Algorithms",
      "url": Astro.site?.href,
    },
  })} />
  <section class="about">
    <Heading as="h1">About</Heading>
    <Prose>
      <p>
        I'm Shreyas Basarge. This is my personal blog where I write about AI, philosophy, leadership and other random stuff. I started this blog to share my thoughts and to connect with like-minded people. If you find it interesting feel free to reach out to me.
      </p>
    </Prose>
  </section>
</Layout>

<style>
  .about {
    max-width: var(--width-content);
  }
</style>
